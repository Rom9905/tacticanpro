        "\u05d1\u05d9\u05e8\u05d9\u05d3\u05d4"
      ],
      "default": "\u05d9\u05e6\u05d9\u05d1",
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05de\u05e7\u05e6\u05d5\u05e2\u05d9"
    },
    "season_goals": {
